# -----------------------------------------------
# Scanlyzer — Environment Variables
# -----------------------------------------------
# Copy env.example to .env and fill in your values.
# ⚠️ NEVER commit this file to Git.

# --- AI Backend Selection ---
# Options: gemini | groq | local
AI_BACKEND=groq

# --- Google Gemini (Free Tier) ---
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Groq Integration ---
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=
# Optional: Override base URL for OpenAI-compatible providers
# GROQ_BASE_URL=https://openrouter.ai/api/v1

# --- Flask Server ---
FLASK_PORT=5000
FLASK_DEBUG=false

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# --- Optional: API key for public-facing endpoints ---
# API_PUBLIC_KEY=

# --- Target Site (for development) ---
TARGET_SITE_URL=http://localhost:8000/
